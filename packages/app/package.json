{
  "name": "@suparun/app",
  "version": "0.0.2",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LivioGama/suparun.git"
  },
  "homepage": "https://github.com/LivioGama/suparun",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:electron": "electron-vite dev",
    "dev:web": "bun run src/web/server.ts & BACKEND_PID=$! && vite --config vite.web.config.ts; kill $BACKEND_PID 2>/dev/null",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "prebuild:mac": "mkdir -p cli && cp ../cli/suparun.sh ../cli/vhost-proxy.ts cli/",
    "build:mac": "electron-vite build && electron-builder --mac",
    "postinstall": "electron-builder install-app-deps && node scripts/patch-electron-name.js"
  },
  "dependencies": {
    "menubar": "^9.5.0",
    "tree-kill": "^1.2.2",
    "fast-glob": "^3.3.3",
    "ansi-to-html": "^0.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.11"
  }
}
